#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper startup script (POSIX)
# ----------------------------------------------------------------------------

set -eu

BASE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
WRAPPER_JAR="$BASE_DIR/.mvn/wrapper/maven-wrapper.jar"

WRAPPER_URL="$(grep -E '^wrapperUrl=' "$BASE_DIR/.mvn/wrapper/maven-wrapper.properties" | cut -d= -f2- || true)"
if [ -z "${WRAPPER_URL:-}" ]; then
  WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
fi

if [ ! -f "$WRAPPER_JAR" ]; then
  mkdir -p "$BASE_DIR/.mvn/wrapper"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$WRAPPER_URL" -o "$WRAPPER_JAR"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$WRAPPER_URL" -O "$WRAPPER_JAR"
  else
    echo "Neither curl nor wget found to download Maven Wrapper." >&2
    exit 1
  fi
fi

MAVEN_PROJECTBASEDIR="$BASE_DIR"
export MAVEN_PROJECTBASEDIR

exec java -jar "$WRAPPER_JAR" "$@"

